# =============================================================================
# Hogar de Ancianos — Backend env example
# Copy to `.env` (development) or `.env.production` and fill the real values.
# NEVER commit `.env` or `.env.production` with real secrets.
# =============================================================================

NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Database (Postgres / Supabase — ÉPICA 2 ✅)
# Set DATABASE_URL for managed Postgres (Supabase, Railway, Render, etc.).
# Leave it empty to use the discrete DB_* vars below (e.g. local Postgres in docker).
# -----------------------------------------------------------------------------
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=hogar_de_ancianos

# Set DB_SSL=true for managed Postgres with TLS (Supabase pooler, RDS, etc.).
# DATABASE_URL with sslmode=require is also auto-detected.
DB_SSL=false

# -----------------------------------------------------------------------------
# Database Logging (TypeORM)
# Set TYPEORM_LOGGING=true ONLY for debugging specific query issues
# Default: false (only SQL errors are logged, not all queries)
# -----------------------------------------------------------------------------
TYPEORM_LOGGING=false

# -----------------------------------------------------------------------------
# Logging Configuration
# LOG_LEVEL: Minimum level to log (fatal, error, warn, info, http, audit, debug, trace)
#            Production default: info
#            Development default: trace
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Supabase Storage (for file uploads - logos, assets)
# Get from: Supabase Dashboard > Project Settings > API
# SUPABASE_URL: Project URL (https://<project-ref>.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY: service_role secret (NOT anon/public)
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Legacy: MySQL (kept temporarily for downgrade path; will be removed in a
# later epic). Install `mysql2` only if you intend to run against MySQL.
# -----------------------------------------------------------------------------
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=
# DB_NAME=hogar_de_ancianos

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=1h

# -----------------------------------------------------------------------------
# Resend (transactional email) — ÉPICA 1 ✅
# Get an API key at https://resend.com
# The sender domain (RESEND_FROM_EMAIL) must be verified in your Resend account.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=Sistema Hogar de Ancianos

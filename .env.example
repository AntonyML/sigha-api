# =============================================================================
# Hogar de Ancianos — Backend env example
# Copy to `.env` (development) or `.env.production` and fill the real values.
# NEVER commit `.env` or `.env.production` with real secrets.
# =============================================================================

NODE_ENV=development
PORT=3000

# Database (MySQL today; Postgres/Supabase target — see EPICA 2 in TareasPendientes.md)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=hogar_de_ancianos

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=1h

# 2FA flag
FA2_ENABLED=true

# Resend (transactional email) — see EPICA 1
# Get an API key at https://resend.com
# The sender domain (RESEND_FROM_EMAIL) must be verified in your Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=Sistema Hogar de Ancianos
